# Copy this file to .env and adjust as needed.
# The app reads these via os.getenv() — a .env file isn't auto-loaded unless
# you `export $(cat .env | xargs)` or use a tool like python-dotenv.

# SQLAlchemy database URL. Defaults to a local SQLite file if unset.
DATABASE_URL=sqlite:///./kana_trainer.db

# Secret key used to sign JWTs. MUST be changed to a long random value in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
